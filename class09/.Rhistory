geom_point(col=my_cols) +
geom_text()
ggplot(pca$rotation)+
aes(PC1, row.names(pca$rotation)) +
geom_col()
ggplot(pca$rotation) +
aes(PC1,
reorder(row.names(pca$rotation), PC1)) +
geom_col()
