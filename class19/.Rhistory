wt_letters <- strsplit(wt, "")[[1]]
mut_letters <- strsplit(mut, "")[[1]]
for (i in 1:length(wt_letters)) {
if (wt_letters[i] != mut_letters[i]) {
cat(wt_letters[i], i, mut_letters[i], "\n")
}
}
if (all(in_domain)) {
cat("All mutations cluster in the", domain_name, "domain (", pfam_id, ").\n")
} else if (any(in_domain)) {
cat("Some mutations fall in the", domain_name, "domain (", pfam_id, ").\n")
} else {
cat("The mutations do not cluster in this domain.\n")
}
# Approximate kinase domain coordinates for ERBB2 protein
domain_start <- 720
domain_end   <- 976
domain_name  <- "Pkinase_Tyr"
pfam_id      <- "PF07714"
in_domain <- mut_pos >= domain_start & mut_pos <= domain_end
