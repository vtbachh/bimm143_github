generate_dna <- function(len=6) {
ans <- sample(c("A", "C", "G", "T"), size =len, replace= TRUE)
return(ans)
}
generate_dna()
generate_dna <- function(len=6) {
ans <- sample(c("A", "C", "G", "T"), size =len, replace= TRUE)
ans <- paste(ans, collapse= "")
return(ans)
}
generate_dna()
generate_dna <- function(len=6, fasta=TRUE) {
ans <- sample(c("A", "C", "G", "T"),
size =len, replace= TRUE)
if(fasta) {
ans <- paste(ans, collapse= "")
}
return(ans)
}
generate_dna()
