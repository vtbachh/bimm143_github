ggplot(cdc) +
aes(x = Year, y = Cases) +
geom_point() +
geom_line() +
labs(title = "CDC Pertussis Cases Over Time",
x = "Year",
y = "Number of Cases")
ggplot(cdc) +
aes(x = Year, y = Cases) +
geom_point() +
geom_line() +
geom_vline(xintercept = 1946, col="pink", lty=2) +
geom_vline(xintercept = 1996, col="red", lty =2) +
geom_vline(xintercept = 2020, col="purple", lty =2) +
labs(title = "CDC Pertussis Cases Over Time",
x = "Year",
y = "Number of Cases")
